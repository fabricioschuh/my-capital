# Backend environment variables
NODE_ENV=development
PORT=3001

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB (optional: for local DynamoDB)
DYNAMODB_ENDPOINT=http://localhost:8000

# Exchange Rate API
EXCHANGE_RATE_PROVIDER=frankfurter
EXCHANGE_RATE_CACHE_TTL=3600

# App
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=debug

# Authentication
# Username for login
AUTH_USERNAME=admin
# Bcrypt hash of the password (preferred). Generate with:
#   node -e "require('bcrypt').hash('your-password', 10).then(h => console.log(h))"
AUTH_PASSWORD_HASH=
# Legacy plain-text fallback (not recommended for production)
AUTH_PASSWORD=

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d
